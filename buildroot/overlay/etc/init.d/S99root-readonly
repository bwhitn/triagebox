#!/bin/sh
# Remount root filesystem read-only after boot setup is complete.

case "$1" in
    start)
        # Allow temporary opt-out for debugging.
        if grep -qw 'rootrw=1' /proc/cmdline 2>/dev/null; then
            mount -o remount,rw,noatime / 2>/dev/null || true
            exit 0
        fi

        if grep -qs ' / .* ro[ ,]' /proc/mounts; then
            exit 0
        fi

        sync
        mount -o remount,ro,noatime / 2>/dev/null || true
        ;;
esac

exit 0
