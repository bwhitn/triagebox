#!/bin/sh
# Non-blocking boot mount for host-provided virtio-9p share at /root.

ROOT9P_STATE_DIR=/run
[ -d "$ROOT9P_STATE_DIR" ] || ROOT9P_STATE_DIR=/tmp
ROOT9P_MARKER="$ROOT9P_STATE_DIR/root9p-init.started"

load_9p_modules() {
    if command -v modprobe >/dev/null 2>&1; then
        modprobe 9pnet_virtio 2>/dev/null || true
        modprobe 9pnet 2>/dev/null || true
        modprobe 9p 2>/dev/null || true
        return
    fi
    if /bin/busybox --list 2>/dev/null | grep -qx "modprobe"; then
        /bin/busybox modprobe 9pnet_virtio 2>/dev/null || true
        /bin/busybox modprobe 9pnet 2>/dev/null || true
        /bin/busybox modprobe 9p 2>/dev/null || true
    fi
}

discover_9p_tag() {
    for tag_path in /sys/bus/virtio/drivers/9pnet_virtio/virtio*/mount_tag /sys/bus/virtio/devices/virtio*/mount_tag; do
        [ -r "$tag_path" ] || continue
        tag_name="$(tr -d '\r\n' < "$tag_path" 2>/dev/null || true)"
        if [ -n "$tag_name" ]; then
            echo "$tag_name"
            return 0
        fi
    done
    echo "host9p"
    return 0
}

is_mounted() {
    grep -qs ' /root 9p ' /proc/mounts
}

mount_with_tag() {
    tag_name="$1"
    mount -t 9p -o trans=virtio,version=9p2000.L,cache=loose,msize=262144 "$tag_name" /root 2>/dev/null && return 0
    mount -t 9p -o trans=virtio,version=9p2000.L "$tag_name" /root 2>/dev/null && return 0
    mount -t 9p "$tag_name" /root 2>/dev/null && return 0
    return 1
}

try_mount_once() {
    tag_name="$(discover_9p_tag)"
    mount_with_tag "$tag_name" && return 0
    if [ "$tag_name" != "host9p" ]; then
        mount_with_tag "host9p" && return 0
    fi
    return 1
}

case "$1" in
    start)
        mkdir -p /root
        if is_mounted; then
            exit 0
        fi
        if [ -e "$ROOT9P_MARKER" ]; then
            exit 0
        fi
        : > "$ROOT9P_MARKER" 2>/dev/null || true

        (
            attempts=0
            while [ "$attempts" -lt 180 ]; do
                if is_mounted; then
                    exit 0
                fi
                if [ $((attempts % 10)) -eq 0 ]; then
                    load_9p_modules
                fi
                if try_mount_once; then
                    echo "Mounted host 9p on /root"
                    exit 0
                fi
                attempts=$((attempts + 1))
                sleep 1
            done
            echo "Warning: failed to mount host 9p on /root after retries" >&2
        ) &
        ;;
esac

exit 0
