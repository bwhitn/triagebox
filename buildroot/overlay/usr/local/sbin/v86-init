#!/bin/sh
set -eu

mkdir -p /dev /proc /sys /run /tmp

mount -t devtmpfs devtmpfs /dev 2>/dev/null || true
mount -t proc proc /proc 2>/dev/null || true
mount -t sysfs sysfs /sys 2>/dev/null || true
mount -t tmpfs tmpfs /run 2>/dev/null || true
chmod 1777 /tmp 2>/dev/null || true
if command -v ip >/dev/null 2>&1; then
    ip link set lo up 2>/dev/null || true
elif command -v ifconfig >/dev/null 2>&1; then
    ifconfig lo up 2>/dev/null || true
fi

case "${TERM:-}" in
    ""|linux|vt100|vt220)
        export TERM=xterm
        ;;
esac

echo ""
echo "Buildroot Linux running on v86"
echo "Type 'poweroff -f' to stop, or 'reboot -f' to restart."
echo ""

launch_shell() {
    if command -v cttyhack >/dev/null 2>&1; then
        setsid cttyhack /bin/sh -l
        return
    fi
    if /bin/busybox --list 2>/dev/null | grep -qx "cttyhack"; then
        setsid /bin/busybox cttyhack /bin/sh -l
        return
    fi
    if [ -c /dev/ttyS0 ]; then
        # Fallback path when cttyhack is unavailable:
        # open ttyS0 as a session leader so it becomes controlling TTY.
        setsid /bin/sh -c '
            stty sane intr ^C quit ^\\ erase ^? kill ^U eof ^D < /dev/ttyS0 >/dev/ttyS0 2>&1 || true
            exec /bin/sh -l < /dev/ttyS0 > /dev/ttyS0 2>&1
        '
        return
    fi
    /bin/sh -l
}

while true; do
    launch_shell
    echo "Shell exited; restarting shell in 1s..."
    sleep 1
done
