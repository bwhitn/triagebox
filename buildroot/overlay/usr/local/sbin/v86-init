#!/bin/sh
set -eu

mkdir -p /dev /proc /sys /run /tmp

mount -t devtmpfs devtmpfs /dev 2>/dev/null || true
mount -t proc proc /proc 2>/dev/null || true
mount -t sysfs sysfs /sys 2>/dev/null || true
mount -t tmpfs tmpfs /run 2>/dev/null || true
chmod 1777 /tmp 2>/dev/null || true
if command -v ip >/dev/null 2>&1; then
    ip link set lo up 2>/dev/null || true
    ip addr add 127.0.0.1/8 dev lo 2>/dev/null || ip addr replace 127.0.0.1/8 dev lo 2>/dev/null || true
elif command -v ifconfig >/dev/null 2>&1; then
    ifconfig lo 127.0.0.1 netmask 255.0.0.0 up 2>/dev/null || ifconfig lo up 2>/dev/null || true
fi

case "${TERM:-}" in
    ""|linux|vt100|vt220)
        export TERM=xterm
        ;;
esac

run_stty() {
    if command -v stty >/dev/null 2>&1; then
        stty "$@"
        return
    fi
    if /bin/busybox --list 2>/dev/null | grep -qx "stty"; then
        /bin/busybox stty "$@"
        return
    fi
    return 127
}

run_stty sane opost onlcr 2>/dev/null || true

set_term_dimensions() {
    size="$(run_stty size 2>/dev/null || true)"
    case "$size" in
        [0-9]*" "[0-9]*)
            rows="${size%% *}"
            cols="${size##* }"
            if [ "${rows:-0}" -gt 1 ] 2>/dev/null; then
                export LINES="$rows"
            fi
            if [ "${cols:-0}" -gt 1 ] 2>/dev/null; then
                export COLUMNS="$cols"
            fi
            ;;
    esac
}

set_term_dimensions

is_root_share_mounted() {
    grep -qs ' /root 9p ' /proc/mounts
}

mount_root_share_once() {
    mount -t 9p -o trans=virtio,version=9p2000.L,cache=loose,msize=262144 host9p /root 2>/dev/null && return 0
    mount -t 9p -o trans=virtio,version=9p2000.L host9p /root 2>/dev/null && return 0
    mount -t 9p host9p /root 2>/dev/null && return 0
    return 1
}

mount_root_share() {

    mkdir -p /root
    # Virtio-9p device can appear slightly after init starts; retry briefly.
    attempts=20
    while [ "$attempts" -gt 0 ]; do
        if is_root_share_mounted; then
            echo "Mounted host9p on /root"
            return 0
        fi
        if mount_root_share_once; then
            echo "Mounted host9p on /root"
            return 0
        fi
        attempts=$((attempts - 1))
        sleep 0.25
    done

    # Keep retrying in background so /root auto-attaches once host9p is ready.
    (
        bg_attempts=0
        while [ "$bg_attempts" -lt 300 ]; do
            if is_root_share_mounted; then
                exit 0
            fi
            if mount_root_share_once; then
                echo "Mounted host9p on /root (background)"
                exit 0
            fi
            bg_attempts=$((bg_attempts + 1))
            sleep 1
        done
        echo "Warning: failed to mount host9p on /root after background retries" >&2
    ) &

    echo "Info: host9p not ready during early boot; retrying in background"
    return 1
}

mount_root_share || true

echo ""
echo "Buildroot Linux running on v86"
echo "Type 'poweroff -f' to stop, or 'reboot -f' to restart."
echo ""

launch_shell() {
    run_setsid() {
        if command -v setsid >/dev/null 2>&1; then
            setsid "$@"
            return
        fi
        if /bin/busybox --list 2>/dev/null | grep -qx "setsid"; then
            /bin/busybox setsid "$@"
            return
        fi
        "$@"
    }

    if command -v cttyhack >/dev/null 2>&1; then
        run_setsid cttyhack /bin/sh -c '
            /bin/busybox stty sane opost onlcr 2>/dev/null || stty sane opost onlcr 2>/dev/null || true
            _sz="$(/bin/busybox stty size 2>/dev/null || stty size 2>/dev/null || true)"
            case "$_sz" in [0-9]*" "[0-9]*) export LINES="${_sz%% *}" COLUMNS="${_sz##* }" ;; esac
            exec /bin/sh -l
        '
        return
    fi
    if /bin/busybox --list 2>/dev/null | grep -qx "cttyhack"; then
        run_setsid /bin/busybox cttyhack /bin/sh -c '
            /bin/busybox stty sane opost onlcr 2>/dev/null || stty sane opost onlcr 2>/dev/null || true
            _sz="$(/bin/busybox stty size 2>/dev/null || stty size 2>/dev/null || true)"
            case "$_sz" in [0-9]*" "[0-9]*) export LINES="${_sz%% *}" COLUMNS="${_sz##* }" ;; esac
            exec /bin/sh -l
        '
        return
    fi
    if [ -c /dev/ttyS0 ]; then
        # Fallback path when cttyhack is unavailable:
        # open ttyS0 as a session leader so it becomes controlling TTY.
        run_setsid /bin/sh -c '
            /bin/busybox stty sane opost onlcr intr ^C quit ^\\ erase ^? kill ^U eof ^D < /dev/ttyS0 >/dev/ttyS0 2>&1 \
                || stty sane opost onlcr intr ^C quit ^\\ erase ^? kill ^U eof ^D < /dev/ttyS0 >/dev/ttyS0 2>&1 \
                || true
            _sz="$(/bin/busybox stty size < /dev/ttyS0 2>/dev/null || stty size < /dev/ttyS0 2>/dev/null || true)"
            case "$_sz" in [0-9]*" "[0-9]*) export LINES="${_sz%% *}" COLUMNS="${_sz##* }" ;; esac
            exec /bin/sh -l < /dev/ttyS0 > /dev/ttyS0 2>&1
        '
        return
    fi
    /bin/sh -l
}

while true; do
    launch_shell
    echo "Shell exited; restarting shell in 1s..."
    sleep 1
done
