config BR2_PACKAGE_PYTHON_PYZBAR
	bool "python-pyzbar"
	depends on BR2_PACKAGE_PYTHON3
	depends on BR2_TOOLCHAIN_HAS_THREADS
	depends on BR2_USE_MMU
	depends on BR2_INSTALL_LIBSTDCPP
	depends on BR2_TOOLCHAIN_HEADERS_AT_LEAST_3_0
	select BR2_PACKAGE_ZBAR
	help
	  Read one-dimensional barcodes and QR codes from Python.

	  https://github.com/NaturalHistoryMuseum/pyzbar/

comment "python-pyzbar needs a toolchain w/ threads, C++ and headers >= 3.0"
	depends on BR2_PACKAGE_PYTHON3
	depends on !BR2_USE_MMU || !BR2_TOOLCHAIN_HAS_THREADS \
		|| !BR2_INSTALL_LIBSTDCPP || !BR2_TOOLCHAIN_HEADERS_AT_LEAST_3_0
