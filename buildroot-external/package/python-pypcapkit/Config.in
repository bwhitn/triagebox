config BR2_PACKAGE_PYTHON_PYPCAPKIT
	bool "python-pypcapkit"
	depends on BR2_PACKAGE_PYTHON3
	select BR2_PACKAGE_PYTHON_AENUM
	select BR2_PACKAGE_PYTHON_DICTDUMPER
	select BR2_PACKAGE_PYTHON_TBTRIM
	help
	  PyPCAPKit: comprehensive network packet analysis library

	  https://pypi.org/project/pypcapkit/
